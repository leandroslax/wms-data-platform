{
  "title": "WMS Operations Overview",
  "uid": "wms-overview",
  "schemaVersion": 37,
  "version": 2,
  "refresh": "1m",
  "tags": ["wms"],
  "panels": [
    {
      "id": 1, "gridPos": {"x":0,"y":0,"w":6,"h":4},
      "type": "stat", "title": "Produtos em Risco Crítico",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT COUNT(*) FROM gold.mart_stockout_risk WHERE risk_level = 'critical'", "format": "table", "refId": "A"}],
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color":"green","value":0},{"color":"yellow","value":5},{"color":"red","value":10}]}}}
    },
    {
      "id": 2, "gridPos": {"x":6,"y":0,"w":6,"h":4},
      "type": "stat", "title": "Total de Pedidos",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT COUNT(*) FROM gold.fct_orders", "format": "table", "refId": "A"}],
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color":"blue","value":0}]}}}
    },
    {
      "id": 3, "gridPos": {"x":12,"y":0,"w":6,"h":4},
      "type": "stat", "title": "Pedidos em Aberto",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT COUNT(*) FROM gold.mart_order_sla WHERE sla_status = 'pending'", "format": "table", "refId": "A"}],
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "thresholds": {"steps": [{"color":"blue","value":0}]}}}
    },
    {
      "id": 4, "gridPos": {"x":18,"y":0,"w":6,"h":4},
      "type": "stat", "title": "Produtos Cadastrados",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT COUNT(*) FROM gold.dim_products", "format": "table", "refId": "A"}],
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color":"blue","value":0}]}}}
    },
    {
      "id": 5, "gridPos": {"x":0,"y":4,"w":12,"h":9},
      "type": "table", "title": "Top Produtos — Risco de Ruptura",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT product_id AS \"SKU\", warehouse_id AS \"Armazém\", company_id AS \"Empresa\", product_class AS \"Classe\", current_stock AS \"Estoque Atual\", avg_daily_consumption AS \"Consumo/Dia\", days_to_stockout AS \"Dias até Ruptura\", risk_level AS \"Risco\" FROM gold.mart_stockout_risk ORDER BY CASE risk_level WHEN 'stockout' THEN 0 WHEN 'critical' THEN 1 WHEN 'high' THEN 2 WHEN 'medium' THEN 3 ELSE 4 END, days_to_stockout ASC LIMIT 20", "format": "table", "refId": "A"}],
      "options": {"sortBy": [{"displayName": "Dias até Ruptura", "desc": false}]},
      "fieldConfig": {"overrides": [{"matcher":{"id":"byName","options":"Risco"},"properties":[{"id":"custom.displayMode","value":"color-background"}]}]}
    },
    {
      "id": 6, "gridPos": {"x":12,"y":4,"w":12,"h":9},
      "type": "barchart", "title": "Distribuição de Risco por Armazém",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT warehouse_id AS \"Armazém\", risk_level AS \"Risco\", COUNT(*) AS total FROM gold.mart_stockout_risk GROUP BY 1,2 ORDER BY 1,2", "format": "table", "refId": "A"}],
      "options": {"xField": "Armazém", "stacking": "normal"}
    },
    {
      "id": 7, "gridPos": {"x":0,"y":13,"w":12,"h":9},
      "type": "table", "title": "Pedidos por Tipo de Documento",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT document_type AS \"Tipo\", company_id AS \"Empresa\", COUNT(*) AS \"Qtd\", ROUND(AVG(total_value)::numeric, 2) AS \"Valor Médio\", MIN(issued_at)::date AS \"Primeiro\", MAX(issued_at)::date AS \"Último\" FROM gold.fct_orders GROUP BY 1,2 ORDER BY 3 DESC LIMIT 20", "format": "table", "refId": "A"}]
    },
    {
      "id": 8, "gridPos": {"x":12,"y":13,"w":12,"h":9},
      "type": "table", "title": "Volume de Pedidos por Mês",
      "datasource": "WMS PostgreSQL",
      "targets": [{"rawSql": "SELECT TO_CHAR(issued_month, 'YYYY-MM') AS \"Mês\", company_id AS \"Empresa\", depositor_id AS \"Depositante\", order_count AS \"Pedidos\", ROUND(total_value::numeric, 2) AS \"Valor Total\", ROUND(sla_compliance_pct::numeric, 1) AS \"SLA %\" FROM gold.mart_geo_performance ORDER BY issued_month DESC, order_count DESC LIMIT 20", "format": "table", "refId": "A"}]
    }
  ]
}
