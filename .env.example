# ─────────────────────────────────────────────────────────────
# WMS Data Platform — variáveis de ambiente (local Docker)
# Copie para .env e preencha os valores reais
# NUNCA commite o .env
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=wmsadmin2026

# MinIO (S3 local)
MINIO_ROOT_USER=wmsadmin
MINIO_ROOT_PASSWORD=wmsadmin2026

# Airflow
AIRFLOW_FERNET_KEY=zTGhSjBDfmR1sxlPkQpgfO1h8vMWnYxq2eCdu7KtIaA=

# Anthropic (necessário para os agents)
ANTHROPIC_API_KEY=sk-ant-...

# LangFuse (observabilidade — self-hosted local via Docker)
# Dashboard: http://localhost:3001  |  login: admin@wms.local / wmsadmin2026
# As chaves abaixo são criadas automaticamente pelo container ao inicializar.
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_ENABLED=true
# Segredos internos do LangFuse (podem manter os padrões em ambiente local)
LANGFUSE_NEXTAUTH_SECRET=wms-langfuse-secret-2026
LANGFUSE_SALT=wms-langfuse-salt-2026

# DeepEval (modelo juiz para os evals — usa OpenAI por padrão)
# Para usar Anthropic como juiz: defina DEEPEVAL_MODEL=claude-haiku-4-5-20251001
DEEPEVAL_MODEL=gpt-4o-mini

# Oracle WMS (necessário para extração real — VPN obrigatória)
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
# ORACLE_SID=            # use SID ou SERVICE_NAME, não os dois
ORACLE_USER=
ORACLE_PASSWORD=

# dbt local
DBT_BRONZE_SCHEMA=bronze

# App
APP_ENV=dev
LOG_LEVEL=INFO
